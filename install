#!/usr/bin/env bash

DOTFILES=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)

if ! command -v brew &>/dev/null; then
	/bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi

if ! command -v brew &>/dev/null; then
	if [[ -x /opt/homebrew/bin/brew ]]; then
		eval "$(/opt/homebrew/bin/brew shellenv)"
	elif [[ -x /usr/local/bin/brew ]]; then
		eval "$(/usr/local/bin/brew shellenv)"
	elif [[ -x /home/linuxbrew/.linuxbrew/bin/brew ]]; then
		eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
	fi
fi

if [[ "$(uname -s)" == "Linux" ]]; then
	gsettings set org.gnome.desktop.peripherals.keyboard repeat true
	gsettings set org.gnome.desktop.peripherals.keyboard delay 200
	gsettings set org.gnome.desktop.peripherals.keyboard repeat-interval 20
elif [[ "$(uname -s)" == "Darwin" ]]; then
	defaults write NSGlobalDomain KeyRepeat -int 2
	defaults write NSGlobalDomain InitialKeyRepeat -int 12
	defaults write -g ApplePressAndHoldEnabled -bool false

	# Disable Spotlight indexing on ~/Code to avoid slow file watchers on large trees.
	if [[ -d "$HOME/Code" ]]; then
		sudo mdutil -i off "$HOME/Code"
	fi

	# Aerospace window manager removed; using Ghostty as the macOS terminal.
	brew install ghostty
fi

brew tap shivammathur/php

brew install \
	neovim \
	fd \
	fzf \
	ripgrep \
	git \
	gitui \
	tmux \
	fnm \
	lua \
	php \
	composer

if [ ! -d "$HOME/.oh-my-zsh" ]; then
	curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh | sh
fi

if ! command -v grok &>/dev/null && [[ ! -x "$HOME/.grok/bin/grok" ]]; then
	curl -fsSL https://x.ai/cli/install.sh | bash
fi

rm -rf "$HOME/.zshrc"
ln -s "$DOTFILES/home/zshrc" "$HOME/.zshrc"

rm -rf "$HOME/.gitconfig"
ln -s "$DOTFILES/home/gitconfig" "$HOME/.gitconfig"

rm -rf "$HOME/.gitignore"
ln -s "$DOTFILES/home/gitignore" "$HOME/.gitignore"

rm -rf "$HOME/.ideavimrc"
ln -s "$DOTFILES/home/ideavimrc" "$HOME/.ideavimrc"

rm -rf "$HOME/.tmux.conf"
ln -s "$DOTFILES/tmux/tmux.conf" "$HOME/.tmux.conf"

mkdir -p "$HOME/.local/bin"
rm -rf "$HOME/.local/bin/t"
ln -s "$DOTFILES/scripts/t" "$HOME/.local/bin/t"
rm -rf "$HOME/.local/bin/phpr"
ln -s "$DOTFILES/scripts/phpr" "$HOME/.local/bin/phpr"
rm -rf "$HOME/.local/bin/phpu"
ln -s "$DOTFILES/scripts/phpu" "$HOME/.local/bin/phpu"

chmod +x "$DOTFILES/scripts/t"
chmod +x "$DOTFILES/scripts/phpr"
chmod +x "$DOTFILES/scripts/phpu"

mkdir -p "$HOME/.config/nvim"
rm -rf "$HOME/.config/nvim"
ln -s "$DOTFILES/nvim" "$HOME/.config/nvim"

mkdir -p "$HOME/.config/gitui"
rm -rf "$HOME/.config/gitui"
ln -s "$DOTFILES/gitui" "$HOME/.config/gitui"

mkdir -p "$HOME/.config/ghostty"
rm -rf "$HOME/.config/ghostty/config"
ln -s "$DOTFILES/ghostty/config" "$HOME/.config/ghostty/config"

mkdir -p "$HOME/.config/vscode"
rm -rf "$HOME/.config/vscode"
ln -s "$DOTFILES/vscode" "$HOME/.config/vscode"
