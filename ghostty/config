shell-integration-features = cursor
font-family = Berkeley Mono
# background-opacity = 0.85
# background-blur-radius = 85
# background = 000000
font-size = 18
font-feature = -calt
# adjust-cell-height = 12%
# adjust-cell-width = -1
term = xterm-256color
adjust-cursor-thickness = 4
theme = Grok Dark
window-padding-x = 0
window-padding-y = 0
confirm-close-surface = false
copy-on-select = clipboard
title = " "
macos-titlebar-proxy-icon = hidden
cursor-color = bb9af7
cursor-text = 141414
bell-features = no-system,no-title
progress-style = false

keybind = shift+enter=text:\x1b\r
